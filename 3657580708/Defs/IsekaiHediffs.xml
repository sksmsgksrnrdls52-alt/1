<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!-- ==================== BUFF HEDIFFS ==================== -->
    
    <!-- Berserk Rage -->
    <HediffDef>
        <defName>Isekai_Berserk</defName>
        <label>berserk rage</label>
        <description>In a berserker fury, dealing increased damage but with reduced defense.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <defaultLabelColor>(1, 0.3, 0.3)</defaultLabelColor>
        <isBad>false</isBad>
        <comps>
            <li Class="HediffCompProperties_Disappears">
                <disappearsAfterTicks>1800</disappearsAfterTicks>
            </li>
        </comps>
        <stages>
            <li>
                <label>raging</label>
                <statOffsets>
                    <MeleeDamageFactor>0.5</MeleeDamageFactor>
                </statOffsets>
                <statFactors>
                    <ArmorRating_Sharp>0.75</ArmorRating_Sharp>
                    <ArmorRating_Blunt>0.75</ArmorRating_Blunt>
                </statFactors>
                <capMods>
                    <li>
                        <capacity>Moving</capacity>
                        <offset>0.2</offset>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>

