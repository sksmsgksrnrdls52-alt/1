<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!-- ══════════════════════════════════════════ -->
    <!--  Refinement Forge — Workbench for equipment refinement and mana distillation -->
    <!-- ══════════════════════════════════════════ -->
    <ThingDef ParentName="BenchBase">
        <defName>Isekai_Forge</defName>
        <label>refinement forge</label>
        <description>A mystical forge infused with otherworldly energy. Used to refine weapons and armor to extraordinary levels of power, and to distill mana cores into pure mana essence.

Refinement strengthens equipment from +1 to +10, with increasing risk at higher levels. Equipment above +5 requires rare Reinforcement Cores and risks destruction on failure.</description>
        <thingClass>Building_WorkTable</thingClass>
        <graphicData>
            <texPath>Building/Isekai_Forge</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(3.3,1.3)</drawSize>
            <damageData>
                <cornerTL>Damage/Corner</cornerTL>
                <cornerTR>Damage/Corner</cornerTR>
                <cornerBL>Damage/Corner</cornerBL>
                <cornerBR>Damage/Corner</cornerBR>
            </damageData>
        </graphicData>
        <costList>
            <Steel>200</Steel>
            <ComponentIndustrial>5</ComponentIndustrial>
        </costList>
        <altitudeLayer>Building</altitudeLayer>
        <fillPercent>0.5</fillPercent>
        <useHitPoints>true</useHitPoints>
        <statBases>
            <WorkToBuild>6000</WorkToBuild>
            <MaxHitPoints>200</MaxHitPoints>
            <Flammability>1.0</Flammability>
        </statBases>
        <size>(3,1)</size>
        <designationCategory>Production</designationCategory>
        <passability>PassThroughOnly</passability>
        <pathCost>50</pathCost>
        <hasInteractionCell>True</hasInteractionCell>
        <interactionCellOffset>(0,0,-1)</interactionCellOffset>
        <surfaceType>Item</surfaceType>
        <constructionSkillPrerequisite>5</constructionSkillPrerequisite>
        <inspectorTabs>
            <li>ITab_Bills</li>
        </inspectorTabs>
        <building>
            <spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
        </building>
        <researchPrerequisites>
            <li>Smithing</li>
        </researchPrerequisites>
    </ThingDef>

    <!-- ══════════════════════════════════════════ -->
    <!--  Mana Distillation Recipes (at Refinement Forge) -->
    <!-- ══════════════════════════════════════════ -->
    
    <!-- Distill Small Mana Cores into Mana Essence: 3 Small → 1 Essence -->
    <RecipeDef>
        <defName>Isekai_DistillSmallManaCores</defName>
        <label>distill small mana cores</label>
        <description>Distill 3 small mana cores into 1 vial of pure mana essence.</description>
        <jobString>Distilling mana cores.</jobString>
        <workAmount>500</workAmount>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <effectWorking>Cook</effectWorking>
        <soundWorking>Recipe_Machining</soundWorking>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>Isekai_SmallManaCore</li>
                    </thingDefs>
                </filter>
                <count>3</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>Isekai_SmallManaCore</li>
            </thingDefs>
        </fixedIngredientFilter>
        <products>
            <Isekai_ManaEssence>1</Isekai_ManaEssence>
        </products>
        <recipeUsers>
            <li>Isekai_Forge</li>
        </recipeUsers>
    </RecipeDef>

    <!-- Distill Regular Mana Cores into Mana Essence: 1 Regular → 2 Essence -->
    <RecipeDef>
        <defName>Isekai_DistillManaCores</defName>
        <label>distill mana cores</label>
        <description>Distill 1 mana core into 2 vials of pure mana essence.</description>
        <jobString>Distilling mana cores.</jobString>
        <workAmount>600</workAmount>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <effectWorking>Cook</effectWorking>
        <soundWorking>Recipe_Machining</soundWorking>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>Isekai_ManaCore</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>Isekai_ManaCore</li>
            </thingDefs>
        </fixedIngredientFilter>
        <products>
            <Isekai_ManaEssence>2</Isekai_ManaEssence>
        </products>
        <recipeUsers>
            <li>Isekai_Forge</li>
        </recipeUsers>
    </RecipeDef>

    <!-- Distill Big Mana Cores into Mana Essence: 1 Big → 5 Essence -->
    <RecipeDef>
        <defName>Isekai_DistillBigManaCores</defName>
        <label>distill big mana core</label>
        <description>Distill 1 big mana core into 5 vials of pure mana essence. A significant amount of magical energy is lost in the process, but the resulting essence is invaluable for rune crafting.</description>
        <jobString>Distilling big mana core.</jobString>
        <workAmount>800</workAmount>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <effectWorking>Cook</effectWorking>
        <soundWorking>Recipe_Machining</soundWorking>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>Isekai_BigManaCore</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>Isekai_BigManaCore</li>
            </thingDefs>
        </fixedIngredientFilter>
        <products>
            <Isekai_ManaEssence>5</Isekai_ManaEssence>
        </products>
        <recipeUsers>
            <li>Isekai_Forge</li>
        </recipeUsers>
    </RecipeDef>

    <!-- Distill Huge Mana Cores into Mana Essence: 1 Huge → 12 Essence -->
    <RecipeDef>
        <defName>Isekai_DistillHugeManaCores</defName>
        <label>distill huge mana core</label>
        <description>Distill 1 huge mana core into 12 vials of pure mana essence. The overwhelming magical energy within produces an extraordinary yield, though absorbing the core directly would grant far more raw power.</description>
        <jobString>Distilling huge mana core.</jobString>
        <workAmount>1200</workAmount>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <effectWorking>Cook</effectWorking>
        <soundWorking>Recipe_Machining</soundWorking>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>Isekai_HugeManaCore</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>Isekai_HugeManaCore</li>
            </thingDefs>
        </fixedIngredientFilter>
        <products>
            <Isekai_ManaEssence>12</Isekai_ManaEssence>
        </products>
        <recipeUsers>
            <li>Isekai_Forge</li>
        </recipeUsers>
    </RecipeDef>

    <!-- ══════════════════════════════════════════ -->
    <!--  Runic Station — Workbench for crafting and applying runes -->
    <!-- ══════════════════════════════════════════ -->
    <ThingDef ParentName="BenchBase">
        <defName>Isekai_RunicStation</defName>
        <label>runic station</label>
        <description>An arcane workstation inscribed with ancient runes. Used to craft magical runes from mana essence and socket them into weapons and armor, granting powerful enchantments.

Weapons can hold up to 2 runes. Armor can hold up to 3 runes. Removing a socketed rune destroys it.</description>
        <thingClass>Building_WorkTable</thingClass>
        <graphicData>
            <texPath>Building/Isekai_RunicStation</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(1.1,1.1)</drawSize>
            <damageData>
                <cornerTL>Damage/Corner</cornerTL>
                <cornerTR>Damage/Corner</cornerTR>
                <cornerBL>Damage/Corner</cornerBL>
                <cornerBR>Damage/Corner</cornerBR>
            </damageData>
        </graphicData>
        <!--
            Compatibility note: ComponentIndustrial intentionally removed in favor of
            Gold. Medieval Overhaul replaces vanilla components with "basic components"
            (different defName), so any recipe requiring ComponentIndustrial becomes
            uncraftable when MO is active. Gold is vanilla, never modified by other
            mods, and fits the "arcane workstation" flavor better than industrial
            components anyway.
        -->
        <costList>
            <Steel>150</Steel>
            <Silver>100</Silver>
            <Gold>50</Gold>
        </costList>
        <altitudeLayer>Building</altitudeLayer>
        <fillPercent>0.5</fillPercent>
        <useHitPoints>true</useHitPoints>
        <statBases>
            <WorkToBuild>5000</WorkToBuild>
            <MaxHitPoints>180</MaxHitPoints>
            <Flammability>1.0</Flammability>
        </statBases>
        <size>(1,1)</size>
        <designationCategory>Production</designationCategory>
        <passability>PassThroughOnly</passability>
        <pathCost>50</pathCost>
        <hasInteractionCell>True</hasInteractionCell>
        <interactionCellOffset>(0,0,-1)</interactionCellOffset>
        <surfaceType>Item</surfaceType>
        <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
        <inspectorTabs>
            <li>ITab_Bills</li>
        </inspectorTabs>
        <building>
            <spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
        </building>
        <researchPrerequisites>
            <li>Smithing</li>
        </researchPrerequisites>
    </ThingDef>

    <!-- ══════════════════════════════════════════ -->
    <!--  WorkGiverDefs — Allow pawns to work bills at these benches -->
    <!-- ══════════════════════════════════════════ -->
    <WorkGiverDef>
        <defName>Isekai_DoBillsForge</defName>
        <label>refine at forge</label>
        <giverClass>WorkGiver_DoBill</giverClass>
        <workType>Crafting</workType>
        <priorityInType>95</priorityInType>
        <fixedBillGiverDefs>
            <li>Isekai_Forge</li>
        </fixedBillGiverDefs>
        <verb>refine</verb>
        <gerund>refining at the forge</gerund>
        <requiredCapacities>
            <li>Manipulation</li>
        </requiredCapacities>
        <prioritizeSustains>true</prioritizeSustains>
    </WorkGiverDef>

    <WorkGiverDef>
        <defName>Isekai_DoBillsRunicStation</defName>
        <label>craft at runic station</label>
        <giverClass>WorkGiver_DoBill</giverClass>
        <workType>Crafting</workType>
        <priorityInType>94</priorityInType>
        <fixedBillGiverDefs>
            <li>Isekai_RunicStation</li>
        </fixedBillGiverDefs>
        <verb>craft</verb>
        <gerund>crafting runes at the runic station</gerund>
        <requiredCapacities>
            <li>Manipulation</li>
        </requiredCapacities>
        <prioritizeSustains>true</prioritizeSustains>
    </WorkGiverDef>

</Defs>
