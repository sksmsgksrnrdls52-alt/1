<?xml version="1.0" encoding="utf-8"?>
<Defs>
    
    <!-- ==================== POWER RANK TRAITS ==================== -->
    <!-- These traits are automatically assigned based on a pawn's power level -->
    <!-- They significantly affect social standing, attractiveness, and value -->
    
    <!-- F-Rank: The Weakest -->
    <TraitDef>
        <defName>Isekai_Rank_F</defName>
        <commonality>0</commonality> <!-- Never randomly assigned -->
        <disabledWorkTags />
        <degreeDatas>
            <li>
                <label>Rank F</label>
                <description>This individual is recognized as an F-Rank - the weakest classification. Others look down on them with pity or contempt, and their presence commands no respect.</description>
                <degree>0</degree>
                <statOffsets>
                    <PawnBeauty>-0.5</PawnBeauty>
                    <SocialImpact>-0.30</SocialImpact>
                    <NegotiationAbility>-0.20</NegotiationAbility>
                    <TradePriceImprovement>-0.10</TradePriceImprovement>
                </statOffsets>
                <statFactors>
                    <MarketValue>0.5</MarketValue>
                </statFactors>
                <socialFightChanceFactor>1.3</socialFightChanceFactor>
            </li>
        </degreeDatas>
        <conflictingTraits>
            <li>Isekai_Rank_E</li>
            <li>Isekai_Rank_D</li>
            <li>Isekai_Rank_C</li>
            <li>Isekai_Rank_B</li>
            <li>Isekai_Rank_A</li>
            <li>Isekai_Rank_S</li>
            <li>Isekai_Rank_SS</li>
            <li>Isekai_Rank_SSS</li>
        </conflictingTraits>
    </TraitDef>
    
