            <li>
                <nodeId>LD_Start</nodeId>
                <label>Leader's Awakening</label>
                <description>Others look to you when decisions need making. Your words carry weight, your presence commands attention, and even strangers feel the pull of your authority. Today you begin to understand why.</description>
                <nodeType>Start</nodeType>
                <icon>SkillTree/Icons/star</icon>
                <x>0</x><y>0</y>
                <cost>0</cost>
                <bonuses>
                    <li><bonusType>SocialImpact</bonusType><value>0.0333</value></li>
                    <li><bonusType>Negotiation</bonusType><value>0.0167</value></li>
                </bonuses>
            </li>

            <!-- ══════════════════════════════════════════════════════════ -->
