<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!-- Starter Titles - Earned by leveling -->
    
    <IsekaiLeveling.IsekaiTitleDef>
        <defName>Title_Newcomer</defName>
        <label>Newcomer</label>
        <titleName>Newcomer</titleName>
        <titleDescription>A fresh arrival to this world. The journey has just begun.</titleDescription>
        <unlockType>Level</unlockType>
        <requiredLevel>1</requiredLevel>
        <rarity>Common</rarity>
        <xpGainBonus>0.05</xpGainBonus>
    </IsekaiLeveling.IsekaiTitleDef>
    
    <IsekaiLeveling.IsekaiTitleDef>
        <defName>Title_Adventurer</defName>
        <label>Adventurer</label>
        <titleName>Adventurer</titleName>
        <titleDescription>One who has taken their first steps on the path of power.</titleDescription>
        <unlockType>Level</unlockType>
        <requiredLevel>5</requiredLevel>
        <rarity>Common</rarity>
        <xpGainBonus>0.10</xpGainBonus>
        <allStatsBonus>1</allStatsBonus>
    </IsekaiLeveling.IsekaiTitleDef>
    
    <IsekaiLeveling.IsekaiTitleDef>
        <defName>Title_Veteran</defName>
        <label>Veteran</label>
        <titleName>Veteran</titleName>
        <titleDescription>A seasoned survivor who has proven their worth.</titleDescription>
        <unlockType>Level</unlockType>
        <requiredLevel>10</requiredLevel>
        <rarity>Uncommon</rarity>
        <xpGainBonus>0.15</xpGainBonus>
        <allStatsBonus>2</allStatsBonus>
        <enduranceRegenBonus>0.10</enduranceRegenBonus>
    </IsekaiLeveling.IsekaiTitleDef>
    
    <IsekaiLeveling.IsekaiTitleDef>
        <defName>Title_Elite</defName>
