        <requiredLevel>20</requiredLevel>
        <rarity>Rare</rarity>
        <xpGainBonus>0.20</xpGainBonus>
        <allStatsBonus>3</allStatsBonus>
        <manaRegenBonus>0.15</manaRegenBonus>
        <enduranceRegenBonus>0.15</enduranceRegenBonus>
    </IsekaiLeveling.IsekaiTitleDef>
    
    <IsekaiLeveling.IsekaiTitleDef>
        <defName>Title_Champion</defName>
        <label>Champion</label>
        <titleName>Champion</titleName>
