<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- Make mana cores buyable by most traders by adding them to trader stock generators -->
    <!-- Uses PatchOperationConditional so missing traders don't cause errors -->
    
    <!-- Bulk Goods Traders (Caravans) -->
    <Operation Class="PatchOperationConditional">
        <xpath>/Defs/TraderKindDef[defName="Caravan_Neolithic_BulkGoods"]/stockGenerators</xpath>
        <match Class="PatchOperationAdd">
            <xpath>/Defs/TraderKindDef[defName="Caravan_Neolithic_BulkGoods"]/stockGenerators</xpath>
            <value>
                <li Class="StockGenerator_BuySingleDef">
                    <thingDef>Isekai_SmallManaCore</thingDef>
                </li>
                <li Class="StockGenerator_BuySingleDef">
                    <thingDef>Isekai_ManaCore</thingDef>
                </li>
                <li Class="StockGenerator_BuySingleDef">
                    <thingDef>Isekai_BigManaCore</thingDef>
                </li>
                <li Class="StockGenerator_BuySingleDef">
                    <thingDef>Isekai_HugeManaCore</thingDef>
                </li>
            </value>
        </match>
    </Operation>
    
