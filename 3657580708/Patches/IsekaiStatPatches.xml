<?xml version="1.0" encoding="utf-8"?>
<Patch>
    
    <!-- ==================== STRENGTH STAT PATCHES ==================== -->
    
    <!-- MeleeDamageFactor must not be cached so the Wrath of the Fallen gimmick
         (which reads live HP each frame) reflects instantly in combat and the UI. -->
    <Operation Class="PatchOperationConditional">
        <xpath>/Defs/StatDef[defName="MeleeDamageFactor"]/cacheable</xpath>
        <match Class="PatchOperationReplace">
            <xpath>/Defs/StatDef[defName="MeleeDamageFactor"]/cacheable</xpath>
            <value><cacheable>false</cacheable></value>
        </match>
        <nomatch Class="PatchOperationAdd">
            <xpath>/Defs/StatDef[defName="MeleeDamageFactor"]</xpath>
            <value><cacheable>false</cacheable></value>
        </nomatch>
    </Operation>

