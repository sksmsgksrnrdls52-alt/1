            <xpath>/Defs/StatDef[defName="MeleeDamageFactor"]/parts</xpath>
            <value>
                <li Class="IsekaiLeveling.Stats.StatPart_IsekaiMeleeDamage" />
            </value>
        </match>
        <nomatch Class="PatchOperationAdd">
            <xpath>/Defs/StatDef[defName="MeleeDamageFactor"]</xpath>
            <value>
                <parts>
                    <li Class="IsekaiLeveling.Stats.StatPart_IsekaiMeleeDamage" />
