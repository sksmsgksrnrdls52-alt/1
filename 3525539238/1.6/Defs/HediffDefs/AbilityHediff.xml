<?xml version="1.0" encoding="UTF-8"?>
<Defs>

	<HediffDef>
		<defName>VPE_PerceptionFreeze</defName>
		<label>altered perception</label>
		<description>The sense of perception of this pawn is virtually altered, making them unable to feel pain.</description>
		<defaultLabelColor>(251, 174, 210)</defaultLabelColor>
		<hediffClass>Stunskip.Stunskip_PerceptionFreeze_Hediff</hediffClass>
				<stages>
					<li>	
						<painFactor>0</painFactor>
						<becomeVisible>false</becomeVisible>
					</li>
				</stages>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>30~60</disappearsAfterTicks>
				<showRemainingTime>True</showRemainingTime>
			</li>
		</comps>
	</HediffDef>
	
	<HediffDef>
		<defName>VPE_ProjectilePatch</defName>
		<label>projectile evasion</label>
		<description>Projectiles will not hit this pawn for a short period of time.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<defaultLabelColor>(251, 174, 210)</defaultLabelColor>
		<stages>
			<li>
				<becomeVisible>false</becomeVisible>
			</li>
		</stages>
		<isBad>False</isBad>
		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>120~120</disappearsAfterTicks>
				<showRemainingTime>True</showRemainingTime>
			</li>
		</comps>
	</HediffDef>
	
</Defs>