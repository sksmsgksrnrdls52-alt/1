<?xml version="1.0" encoding="UTF-8"?>
<Defs>
	
	<HediffDef>
		<defName>VPE_stuncaster</defName>
		<label>Stuncaster</label>
		<description>This individual is a stuncaster.</description>
		<defaultLabelColor>(155, 207, 229)</defaultLabelColor>
		<isBad>False</isBad>
		<!--everCurableByItem>false</everCurableByItem-->
		<initialSeverity>0.001</initialSeverity>
		<maxSeverity>3.01</maxSeverity>
		<hediffClass>HediffWithComps</hediffClass>
		<stages>
			<li>
				<overrideLabel>Lesser Stuncaster</overrideLabel>
				<overrideTooltip>This individual just had a taste of Restrain. Over time, their senses will gradually be enhanced.</overrideTooltip>
				<minSeverity>0</minSeverity>
			</li>
			<li>
				<overrideLabel>Stuncaster</overrideLabel>
				<extraTooltip>This stuncaster is a novice and their perceptivity is mildly enhanced.</extraTooltip>
				<minSeverity>0.1</minSeverity>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>0.05</offset>
					</li>
					<li>
						<capacity>Sight</capacity>
						<offset>0.05</offset>
					</li>
					<li>
						<capacity>Hearing</capacity>
						<offset>0.05</offset>
					</li>
				</capMods>
			</li>
			<li>
				<overrideLabel>Greater Stuncaster</overrideLabel>
				<overrideTooltip>This individual has at least a year worth of experience as a stuncaster and their perceptivity is greatly enhanced.</overrideTooltip>
				<minSeverity>0.6</minSeverity>
				<statOffsets>
					<MeleeDodgeChance>10</MeleeDodgeChance>
				</statOffsets>
				<statFactors>
					<PawnTrapSpringChance>0.5</PawnTrapSpringChance>
				</statFactors>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>0.25</offset>
					</li>
					<li>
						<capacity>Sight</capacity>
						<offset>0.25</offset>
					</li>
					<li>
						<capacity>Hearing</capacity>
						<offset>0.25</offset>
					</li>
				</capMods>
			</li>
			<li>
				<overrideLabel>Awakened Stuncaster</overrideLabel>
				<overrideTooltip>With years of patience and experience, this stuncaster's senses are awakened and their awareness has been improved exceptionally.</overrideTooltip>
				<minSeverity>1.2</minSeverity>
				<statOffsets>
					<MentalBreakThreshold>-0.25</MentalBreakThreshold>
					<MeleeDodgeChance>30</MeleeDodgeChance>
					<ShootingAccuracyPawn>2</ShootingAccuracyPawn>
				</statOffsets>
				<statFactors>			
					<PawnTrapSpringChance>0.25</PawnTrapSpringChance>
					<GlobalLearningFactor>1.5</GlobalLearningFactor>
				</statFactors>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<offset>0.5</offset>
					</li>
					<li>
						<capacity>Sight</capacity>
						<offset>0.5</offset>
					</li>
					<li>
						<capacity>Hearing</capacity>
						<offset>0.5</offset>
					</li>
				</capMods>
			</li>
			<li>
			<overrideLabel>Apogee Stuncaster</overrideLabel>
			<overrideTooltip>A master stuncaster with extensive experience since forever ago. Their perceptivity and senses has reached unprecedented levels, tremendously improving their capabilities in combat and handling mundane tasks.</overrideTooltip>
			<minSeverity>3</minSeverity>
			<restFallFactor>0.5</restFallFactor>
			<statOffsets>
				<MentalBreakThreshold>-0.75</MentalBreakThreshold>
				<MeleeDodgeChance>50</MeleeDodgeChance>
				<ShootingAccuracyPawn>4</ShootingAccuracyPawn>
				<WorkSpeedGlobal>0.75</WorkSpeedGlobal>
			</statOffsets>
			<statFactors>				
				<PawnTrapSpringChance>0</PawnTrapSpringChance>
				<GlobalLearningFactor>2</GlobalLearningFactor>
			</statFactors>
			<capMods>
				<li>
					<capacity>Consciousness</capacity>
					<offset>1</offset>
				</li>
				<li>
					<capacity>Sight</capacity>
					<offset>1</offset>
				</li>
				<li>
					<capacity>Hearing</capacity>
					<offset>1</offset>
				</li>
			</capMods>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>0.01</severityPerDay>
			</li>
			<li Class="HediffCompProperties_MessageStageIncreased">
				<message>Stuncaster {0} gained enough experience and have grown stronger.</message>
				<messageType>PositiveEvent</messageType>
			</li>
		</comps>
	</HediffDef>
	
</Defs>